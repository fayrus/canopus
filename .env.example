# ── Server ───────────────────────────────────────────────────────────────────
CANOPUS_DEBUG=false
CANOPUS_PORT=2107

# ── Authentication ────────────────────────────────────────────────────────────
# Leave empty to disable authentication (development only)
CANOPUS_API_KEY=your-secret-api-key

# ── Cipher ────────────────────────────────────────────────────────────────────
# f = Fernet AES-128-CBC (default)
# g = AES-256-GCM        (HIPAA / HITRUST / SOC2 / PCI DSS)
# c = AES-256-CBC        (FIPS 140-2)
CANOPUS_CIPHER=f

# ── Storage backend ───────────────────────────────────────────────────────────
# Options: file | sqlite | database | env | aws_secrets
CANOPUS_STORAGE_BACKEND=file

# file backend
CANOPUS_KEYS_FILE=keys.txt

# sqlite backend
CANOPUS_SQLITE_PATH=canopus.db

# database backend (SQLAlchemy URL)
# CANOPUS_DATABASE_URL=postgresql://user:pass@host:5432/dbname
# CANOPUS_DATABASE_URL=mysql+pymysql://user:pass@host:3306/dbname
# CANOPUS_DATABASE_URL=sqlite:///canopus.db

# env backend (comma-separated Fernet keys — read-only, no rotation)
# CANOPUS_KEYS=base64key1==,base64key2==

# aws_secrets backend
# CANOPUS_AWS_SECRET_NAME=canopus/keys/production
# CANOPUS_AWS_REGION=us-east-1
